# ============================================================
#  .env — segredos do bot Deriv
#  NUNCA commitar este arquivo (já está no .gitignore)
#  Após revogar os tokens antigos, preencha com os novos valores.
# ============================================================

# ── Deriv ────────────────────────────────────────────────────
# Crie/renove em: https://app.deriv.com → Configurações → Tokens de API
# ⚠️  TOKEN ATUAL — substitua após revogar em: https://app.deriv.com → Tokens de API
DERIV_TOKEN=
DERIV_APP_ID=

# ── Firebase ─────────────────────────────────────────────────
# Baixe a chave em: Firebase Console → Configurações do Projeto → Contas de serviço
FIREBASE_CRED_PATH=serviceAccountKey.json
FIREBASE_DB_URL=https://standeriv-default-rtdb.firebaseio.com
FIREBASE_BUCKET=standeriv.firebasestorage.app
