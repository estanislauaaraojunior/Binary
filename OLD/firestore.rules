rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Leitura pública (dashboard sem login).
    // Escrita criada pelo backend (Admin SDK bypassa essas regras).
    // Delete permitido apenas para usuários autenticados (botão "Limpar Dados").
    match /operacoes/{docId} {
      allow read:   if true;
      allow create, update: if false;
      allow delete: if request.auth != null;
    }
    // Negar acesso a qualquer outro caminho por padrão
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
